<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC"
    android:padding="32dp">

    <TextView
        android:id="@+id/tk_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Wallet"
        android:textColor="#1E293B"
        android:textSize="32sp"
        android:fontFamily="sans-serif-black"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="20dp" />

    <EditText
        android:id="@+id/tk_edit_salary"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:layout_marginTop="40dp"
        android:background="#FFFFFF"
        android:hint="Monthly Income"
        android:inputType="numberDecimal"
        android:paddingStart="20dp"
        android:textColor="#1E1B4B"
        android:textColorHint="#94A3B8"
        android:elevation="2dp"
        app:layout_constraintTop_toBottomOf="@id/tk_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <EditText
        android:id="@+id/tk_edit_rent"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:layout_marginTop="16dp"
        android:background="#FFFFFF"
        android:hint="Home Rent"
        android:inputType="numberDecimal"
        android:paddingStart="20dp"
        android:textColor="#1E1B4B"
        android:textColorHint="#94A3B8"
        android:elevation="2dp"
        app:layout_constraintTop_toBottomOf="@id/tk_edit_salary"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <EditText
        android:id="@+id/tk_edit_food"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:layout_marginTop="16dp"
        android:background="#FFFFFF"
        android:hint="Food Expenses"
        android:inputType="numberDecimal"
        android:paddingStart="20dp"
        android:textColor="#1E1B4B"
        android:textColorHint="#94A3B8"
        android:elevation="2dp"
        app:layout_constraintTop_toBottomOf="@id/tk_edit_rent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/tk_btn_calculate"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:layout_marginTop="40dp"
        android:text="Calculate Balance"
        android:textAllCaps="false"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:backgroundTint="#6366F1"
        app:layout_constraintTop_toBottomOf="@id/tk_edit_food"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>